# Atlas Realty — Agent System Environment Variables
# Copy to .env and fill in your values

# LLM Provider (required — pick one or both)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # Optional fallback

# LLM Model Overrides (optional — defaults shown)
PM_MODEL=claude-sonnet-4-6
ARCH_MODEL=claude-sonnet-4-6
DESIGN_MODEL=claude-sonnet-4-6
SECURITY_MODEL=claude-sonnet-4-6
DEV_BACKEND_MODEL=claude-sonnet-4-6
DEV_FRONTEND_MODEL=claude-sonnet-4-6
CODE_REVIEW_MODEL=claude-sonnet-4-6
TEST_MODEL=claude-sonnet-4-6
PERFORMANCE_MODEL=claude-haiku-4-5-20251001
DOCS_MODEL=claude-haiku-4-5-20251001

# Postgres Checkpointer (optional — uses in-memory if not set)
# POSTGRES_CHECKPOINTER_URL=postgresql://postgres:postgres@localhost:5432/atlasrealty

# Paths (relative to agent-system/)
STATE_DIR=state
OUTPUT_DIR=output
TEMPLATES_DIR=templates
PROMPTS_DIR=prompts
